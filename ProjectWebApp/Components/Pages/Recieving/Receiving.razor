@page "/Receiving"
@using ReceivingSystem.BLL;
@using ReceivingSystem.ViewModels;
@inject AuthenticationStateProvider AuthenticationStateProvider;

<AuthorizeView Context="authCtx">
    <Authorized Context="authUser">
        <MudContainer MaxWidth="MaxWidth.False" Class="content-container">
            <MudDivider Class="mb-4" />

            @if (hasError)
            {
                <MudAlert Elevation="2" Severity="Severity.Error" Dense="true">
                    <MudText Typo="Typo.h6">@errorMessage</MudText>
                    @foreach (var error in errorDetails)
                    {
                        <MudText Typo="Typo.body2">@error</MudText>
                    }
                </MudAlert>
            }

            @if (hasFeedback)
            {
                <MudAlert Elevation="2" Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.body2">@feedbackMessage</MudText>
                </MudAlert>
            }

            <MudText Typo="Typo.h3">eBikes Receiving</MudText>
            <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="mb-3">
                <MudNumericField @bind-Value="purchaseOrderNumber"
                                 Adornment="Adornment.End"
                                 AdornmentColor="Color.Secondary"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 HideSpinButtons="true"
                                 Label="PO Number"
                                 Margin="Margin.Dense"
                                 OnAdornmentClick="Search"
                                 Variant="Variant.Outlined" />
            </MudStack>

            @if (PurchaseOrder.Count > 0)
            {
                <MudPaper Elevation="4" Class="pa-3 mb-4">
                    <MudTable Items="PurchaseOrder" Dense="true" Hover="true" Bordered="true" Class="mb-4" RowTemplateContext="po">
                        <HeaderContent>
                            <MudTh>PO #</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Vendor</MudTh>
                            <MudTh>Contact #</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="po">
                            <MudTd>@po.PurchaseOrderNumber</MudTd>
                            <MudTd>@po.OrderDate?.ToShortDateString()</MudTd>
                            <MudTd>@po.VendorName</MudTd>
                            <MudTd>@po.VendorPhone</MudTd>
                            <MudTd>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => ViewOrder(po)">
                                    View Order
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            }

            @if (selectedOrder != null)
            {
                <MudText Typo="Typo.subtitle1" style="text-align: center;">
                    PO #: @selectedOrder.PurchaseOrderNumber | Vendor: @selectedOrder.VendorName | Phone: @selectedOrder.VendorPhone
                </MudText>

                <MudPaper Elevation="4" Class="pa-3 mb-4">
                    <MudText Typo="Typo.h6">Order Details</MudText>
                    <MudTable Items="OrderDetails" Dense="true" Hover="true" Bordered="true" RowTemplateContext="detail">
                        <HeaderContent>
                            <MudTh>Part ID</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Order Qty</MudTh>
                            <MudTh>Outstanding</MudTh>
                            <MudTh>Received</MudTh>
                            <MudTh>Returned</MudTh>
                            <MudTh>Reason</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="detail">
                            <MudTd>@detail.PartID</MudTd>
                            <MudTd>@detail.Description</MudTd>
                            <MudTd>@detail.QOO</MudTd>
                            <MudTd>@detail.Outstanding</MudTd>
                            <MudTd>
                                <MudNumericField @bind-Value="detail.ReceiveQuantity" T="int" Min="0" Max=@detail.Outstanding Dense="true" Margin="Margin.Dense" />
                            </MudTd>
                            <MudTd>
                                <MudNumericField @bind-Value="detail.ReturnQuantity" T="int" Min="0" Max=@detail.Outstanding Dense="true" Margin="Margin.Dense" />
                            </MudTd>
                            <MudTd>
                                <MudTextField @bind-Value="detail.Reason" Dense="true" Margin="Margin.Dense" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>

                <MudStack Row="true" Spacing="2" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Receive">Receive</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ForceClose">Force Close</MudButton>
                    <MudTextField Label="Reason for Closing" @bind-Value="forceCloseReason" Class="w-50" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Reset">Reset</MudButton>
                </MudStack>

                <MudPaper Elevation="4" Class="pa-3 mt-4">
                    <MudText Typo="Typo.h6">Unordered Items to Return</MudText>
                    <MudGrid Class="mb-3">
                        <MudItem xs="4">
                            <MudTextField Label="Description" @bind-Value="newUnorderedItem.Description" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField Label="Vendor Part ID" @bind-Value="newUnorderedItem.VendorPartNumber" />
                        </MudItem>
                        <MudItem xs="2">
                            <MudNumericField T="int" Label="Qty" @bind-Value="newUnorderedItem.Quantity" />
                        </MudItem>
                        <MudItem xs="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="InsertUnorderedItem">
                                Insert
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    <MudTable Items="UnorderedItems" Dense="true" Hover="true" Bordered="true" RowTemplateContext="unorderedItem">
                        <HeaderContent>
                            <MudTh>Description</MudTh>
                            <MudTh>Vendor Part ID</MudTh>
                            <MudTh>Qty</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="unorderedItem">
                            <MudTd>@unorderedItem.Description</MudTd>
                            <MudTd>@unorderedItem.VendorPartNumber</MudTd>
                            <MudTd>@unorderedItem.Quantity</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="() => RemoveUnorderedItem(unorderedItem)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            }
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <p>You are not authorized to view this content.</p>
    </NotAuthorized>
</AuthorizeView>
